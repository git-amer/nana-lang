{
  "name": "nana-lang",
  "displayName": "Banana Language",
  "description": "VS Code support for the Banana Data Interchange and Markup Language (.nana-lang).",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "banana",
    "nana",
    "markup",
    "data",
    "language",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:nana"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nana",
        "aliases": [
          "Banana Language",
          "Nana"
        ],
        "extensions": [
          ".nana-lang"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nana",
        "scopeName": "source.nana",
        "path": "./syntaxes/nana.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nana",
        "path": "./snippets/nana.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5"
  }
}
